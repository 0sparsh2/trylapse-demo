{
  "name": "trylapse-product-video",
  "version": "1.0.0",
  "description": "TryLapse SaaS showcase demo video built with Remotion",
  "scripts": {
    "preview": "remotion preview src/index.tsx",
    "render": "remotion render src/index.tsx TryLapseDemo --output=out/trylapse-demo.mp4 --codec=h264",
    "render:gif": "remotion render src/index.tsx TryLapseDemo --output=out/trylapse-demo.gif --codec=gif"
  },
  "dependencies": {
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.419"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.419",
    "@types/react": "^18.3.3",
    "typescript": "^5.4.5"
  }
}
